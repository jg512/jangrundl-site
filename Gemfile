source "https://rubygems.org"

# This single gem mirrors exactly what GitHub Pages runs on the server,
# so a local preview matches the live site. Only needed for local testing.
gem "github-pages", group: :jekyll_plugins

# Plugins (also bundled by github-pages, listed here for clarity)
gem "jekyll-feed"
gem "jekyll-seo-tag"

# Helps on newer Ruby versions
gem "webrick", "~> 1.8"
